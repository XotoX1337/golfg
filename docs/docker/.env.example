# Secrets and overrides for the golfg container.
# Copy to ".env" (gitignored) and fill in what you need. ENV always wins over
# golfg.toml, so nothing here has to be written to a file inside the volume.
#
# Leave everything blank to run in dev mode: no SSO, and Teams posts are only
# logged instead of sent.

# Entra ID / OIDC (leave empty to disable auth)
GOLFG_AUTH_TENANT_ID=
GOLFG_AUTH_CLIENT_ID=
GOLFG_AUTH_CLIENT_SECRET=

# Microsoft Teams incoming webhook (leave empty to only log posts)
GOLFG_TEAMS_WEBHOOK_URL=
